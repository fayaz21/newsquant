# Copy this file to .env and fill in your values.
# Only the keys for sources you actually use are required.

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite. For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./financial_news.db

# ── API Keys (only needed for the matching source) ────────────────────────────
# Scraper(sources=["newsapi"])  — https://newsapi.org/register
NEWSAPI_KEY=

# Scraper(sources=["finnhub"])  — https://finnhub.io/register
FINNHUB_API_KEY=

# ── HTTP Tuning (optional — defaults shown) ───────────────────────────────────
# DEFAULT_RATE_LIMIT_RPS=2.0
# REQUEST_TIMEOUT_SECONDS=30
# MAX_RETRIES=3

# ── Quality Thresholds (optional — defaults shown) ────────────────────────────
# MIN_WORD_COUNT=150
# LANGUAGE_CONFIDENCE_THRESHOLD=0.95

# ── Backfill / Batch (CLI only) ───────────────────────────────────────────────
# BACKFILL_WORKERS=4
# BATCH_SIZE=10000

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
